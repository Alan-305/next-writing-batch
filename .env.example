# このファイルをコピーして .env.local を作成してください（.env.local は Git に含まれません）。
#   cp .env.example .env.local
# 値を埋めたら開発サーバーを再起動します。

# --- Claude（添削で必須）---
ANTHROPIC_API_KEY=
# 任意: モデル名とフォールバック（カンマ区切り）
# CLAUDE_MODEL=claude-3-5-sonnet-20241022
# CLAUDE_MODEL_FALLBACKS=

# --- Gemini（OCR/課題画像取り込みで使用する場合のみ）---
# GEMINI_API_KEY=
# GOOGLE_API_KEY=

# --- GCS / Day4 バッチ（使う場合のみ）---
# Python 子プロセス用。Next が読む場合は export なしの KEY=value でも可。
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# GCS_BUCKET_NAME=
# GCS_SIGNED_URL_EXPIRE_DAYS=180
#
# GCS を置かないローカル開発: NODE_ENV が production 以外かつ GCS_BUCKET_NAME 未設定なら、
# 運用の「確定（Day4 生成）」からバッチを叩くとき --allow-local-qr が自動で付きます（相対 URL の QR）。
# 無効にしたいときだけ false を明示:
# DAY4_ALLOW_LOCAL_QR=false

# --- 任意 ---
# 校正バッチで使う Python 実行ファイルのパス
# PROOFREAD_PYTHON=

# 本番で ops の Claude キー書き込み API を許可する場合のみ true
# OPS_ALLOW_ANTHROPIC_KEY_FILE=true
# （OCR 用 Gemini キー保存を本番で許可する場合）
# OPS_ALLOW_GEMINI_KEY_FILE=true

# 日本語 PDF 用フォント（未設定時は自動ダウンロード）
# DAY4_JP_FONT=
