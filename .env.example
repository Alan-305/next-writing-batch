# このファイルをコピーして .env.local を作成してください（.env.local は Git に含まれません）。
#   cp .env.example .env.local
# 値を埋めたら開発サーバーを再起動します。

# --- Claude（添削で必須）---
ANTHROPIC_API_KEY=
# 任意: モデル名とフォールバック（カンマ区切り）
# CLAUDE_MODEL=claude-3-5-sonnet-20241022
# CLAUDE_MODEL_FALLBACKS=

# --- Gemini（OCR/課題画像取り込みで使用する場合のみ）---
# GEMINI_API_KEY=
# GOOGLE_API_KEY=

# --- GCS / Day4 バッチ（使う場合のみ）---
# Python 子プロセス用。Next が読む場合は export なしの KEY=value でも可。
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# GCS_BUCKET_NAME=
# GCS_SIGNED_URL_EXPIRE_DAYS=180
#
# --- Day4（GCS なしでも可・既定は QR なし）---
# 運用の「確定（Day4 生成）」は既定で QR を出さず、音声は /output/audio/...（任意で AUDIO_BASE_URL）。
# 将来 QR を付けたいときだけ true（要 GCS または下の DAY4_ALLOW_LOCAL_QR 運用）:
# DAY4_ENABLE_QR=true
#
# QR オンで GCS なしのローカル／試験: DAY4_ALLOW_LOCAL_QR=true と AUDIO_BASE_URL=https://公開ドメイン（末尾スラッシュなし）
# GCS を置かないローカル開発: NODE_ENV が production 以外かつ GCS_BUCKET_NAME 未設定なら --allow-local-qr が自動付与（QR オン時向け）
# DAY4_ALLOW_LOCAL_QR=false

# --- 任意 ---
# 校正バッチで使う Python 実行ファイルのパス
# PROOFREAD_PYTHON=

# 本番で ops の Claude キー書き込み API を許可する場合のみ true
# OPS_ALLOW_ANTHROPIC_KEY_FILE=true
# （OCR 用 Gemini キー保存を本番で許可する場合）
# OPS_ALLOW_GEMINI_KEY_FILE=true

# 日本語 PDF 用フォント（未設定時は自動ダウンロード）
# DAY4_JP_FONT=

# --- Firebase（検証は共通テスト環境 / 本番は nexus0301）---
# Firebase Console の「プロジェクトの設定」→ マイアプリ → SDK の設定・構成から Web 用の値をコピー。
# .env.local にのみ書き、Git にコミットしないこと。
#
# NEXT_PUBLIC_FIREBASE_API_KEY=
# プロジェクト ID は Console の値どおり（例: nexus0101-35b17）
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=nexus0101-35b17.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=nexus0101-35b17
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=nexus0101-35b17.firebasestorage.app
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
#
# 管理画面 /admin 用：管理者の Auth uid をカンマ区切り（松尾さんの uid のみ推奨）
# NEXT_PUBLIC_FIREBASE_ADMIN_UIDS=
#
# Emulator を使う場合（未設定なら上記 projectId のプロジェクトに直接接続）
# NEXT_PUBLIC_FIREBASE_USE_EMULATOR=false
# NEXT_PUBLIC_FIREBASE_EMULATOR_HOST=127.0.0.1
#
# Firestore ルールはリポジトリの firestore.rules。デプロイ（要 firebase login）:
#   npm run firebase:deploy-rules
#
# Cloud Functions（Auth onCreate など）は functions/ をビルドしてデプロイ:
#   npm run firebase:deploy-functions
#
# デプロイで「gcf-sources-... bucket denied」と出る場合は IAM（Compute デフォルト SA に Storage Object Viewer）を付与。
# イメージ保持の対話プロンプト: npm run firebase:deploy-functions が事前に setpolicy 済み。
# それでも出る場合: npm run firebase:functions:opt-out-artifact-cleanup
# 詳細: functions/DEPLOY-NOTES.txt
#
# Resend（ウェルカムメール）は Functions の環境変数として設定（Secret Manager 推奨）例:
#   firebase functions:secrets:set RESEND_API_KEY
#   （RESEND_FROM は任意、未設定時は Resend の検証用 from に近い既定）
