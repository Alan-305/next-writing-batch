# functions/.env.local を作るときのテンプレート（.env.local は Git に含めない）
# ルートの .env.local の NEXT_PUBLIC_FIREBASE_ADMIN_UIDS と同じ UID を1つ書く。
ADMIN_UIDS=

# Stripe（テスト／本番は Secret 推奨）
# 機密は Secret Manager + defineSecret でバインド（firebase functions:secrets:set STRIPE_SECRET_KEY 等）
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# RESEND_API_KEY=
# Stripe Checkout（チケットパック）— Dashboard で Price を作成し ID を設定
# STRIPE_PRICE_T10=
# STRIPE_PRICE_T30=
# STRIPE_PRICE_T60=
# STRIPE_PRICE_T120=
#
# Resend（ウェルカムメール）— RESEND_API_KEY は Cloud Console / Secret。送信元は必須。
# プロジェクト別: .env.nexus0101-35b17 等（firebase deploy で注入）
# RESEND_FROM_EMAIL=添削革命 <noreply@nexus-learning.com>
# NWB_PUBLIC_APP_URL=https://your-service.run.app
